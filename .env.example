# -------------------------
# Runtime mode
# -------------------------
VITE_MOCK_DATA=true
VITE_ENABLE_WS=true
VITE_API_TIMEOUT_MS=12000

# -------------------------
# Chain selection
# -------------------------
# Preferred chain alias (ethereum|base|arbitrum|sepolia).
VITE_CHAIN=sepolia
# Comma-separated list of available chain IDs in UI/wallet config.
VITE_AVAILABLE_CHAINS=11155111
# Active/default chain used for reads and default addresses.
VITE_DEFAULT_CHAIN_ID=11155111

# Legacy fallback variables (still supported)
VITE_CHAIN_ID=11155111
VITE_RPC_URL=https://rpc.sepolia.org

# Per-chain RPC + explorer URLs
VITE_RPC_URL_11155111=https://rpc.sepolia.org
VITE_RPC_URL_8453=https://mainnet.base.org
VITE_RPC_URL_42161=https://arb1.arbitrum.io/rpc
VITE_RPC_URL_1=https://rpc.ankr.com/eth

VITE_BLOCK_EXPLORER_URL_11155111=https://sepolia.etherscan.io
VITE_BLOCK_EXPLORER_URL_8453=https://basescan.org
VITE_BLOCK_EXPLORER_URL_42161=https://arbiscan.io
VITE_BLOCK_EXPLORER_URL_1=https://etherscan.io

# -------------------------
# Backend integration
# -------------------------
VITE_API_BASE_URL=https://api.hubris.example
VITE_WS_URL=wss://api.hubris.example/ws

# API endpoint roots (swappable backend routing)
VITE_ENDPOINT_MARKETS=/markets
VITE_ENDPOINT_ORDERS=/orders
VITE_ENDPOINT_POSITIONS=/positions
VITE_ENDPOINT_PORTFOLIO=/portfolio
VITE_ENDPOINT_SHARES=/shares
VITE_ENDPOINT_WORLD_ID_SIGNATURE=/world-id/rp-signature
VITE_ENDPOINT_WORLD_ID_VERIFY=/world-id/verify

# -------------------------
# World ID integration
# -------------------------
VITE_WORLD_ID_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_WORLD_ID_ACTION=hubris-human-only-trade
VITE_WORLD_ID_ALLOW_LEGACY_PROOFS=true
VITE_WORLD_ID_ENVIRONMENT=production

# -------------------------
# Contract addresses (active chain aware)
# Use chain-specific variables first; generic fallbacks are supported.
# -------------------------
VITE_MARKET_FACTORY_ADDRESS_11155111=0x0000000000000000000000000000000000000000
VITE_FEE_MANAGER_ADDRESS_11155111=0x0000000000000000000000000000000000000000
VITE_VAULT_ADDRESS_11155111=0x0000000000000000000000000000000000000000
VITE_USDC_ADDRESS_11155111=0x0000000000000000000000000000000000000000
VITE_ORDERBOOK_ADDRESS_11155111=0x0000000000000000000000000000000000000000
VITE_PREDICTION_MARKET_ADDRESS_11155111=0x0000000000000000000000000000000000000000
VITE_SHARE_TOKEN_ADDRESS_11155111=0x0000000000000000000000000000000000000000

# Generic legacy fallbacks
VITE_MARKET_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_FEE_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
